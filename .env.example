# =============================================================================
# ENVIRONMENT CONFIGURATION
# Copy this file to .env and fill in your values
# =============================================================================

# -----------------------------------------------------------------------------
# Database Configuration (Prisma)
# -----------------------------------------------------------------------------
# SQLite database path for development
DATABASE_URL="file:./dev.db"

# For production, use a proper database:
# DATABASE_URL="postgresql://user:password@localhost:5432/semantic_nav"

# -----------------------------------------------------------------------------
# Segmentation Service Configuration
# -----------------------------------------------------------------------------
# WebSocket URL for the Python segmentation backend (client-side)
NEXT_PUBLIC_WS_URL="ws://127.0.0.1:3030"

# HTTP API URL for the segmentation backend (server-side)
SEGMENTATION_API_URL="http://127.0.0.1:3030"

# -----------------------------------------------------------------------------
# Application Configuration
# -----------------------------------------------------------------------------
# Frontend application URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Application port
PORT="3000"

# Node environment
NODE_ENV="development"

# -----------------------------------------------------------------------------
# Authentication (NextAuth.js)
# Optional - uncomment if using authentication
# -----------------------------------------------------------------------------
# NEXTAUTH_SECRET="your-secret-key-here-generate-with-openssl-rand-base64-32"
# NEXTAUTH_URL="http://localhost:3000"

# OAuth Providers (optional)
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""
# GITHUB_CLIENT_ID=""
# GITHUB_CLIENT_SECRET=""

# -----------------------------------------------------------------------------
# Model Configuration (Backend)
# -----------------------------------------------------------------------------
# Path to YOLOv8 model weights (optional, uses default if not set)
# YOLO_MODEL_PATH="yolov8n-seg.pt"

# Enable TensorRT optimization (requires NVIDIA GPU)
# USE_TENSORRT="false"

# Inference device: "cuda", "cpu", "mps"
# INFERENCE_DEVICE="cuda"

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
# Log level: debug, info, warn, error
LOG_LEVEL="info"
