# =============================================================================
# .gitignore - Files and folders that should NOT be committed to Git
# =============================================================================
# These are either:
# 1. Generated during install (node_modules, .venv)
# 2. Build artifacts (.next, __pycache__)
# 3. Local configuration (.env, IDE files)
# 4. System files (.DS_Store, Thumbs.db)
# =============================================================================

# -----------------------------------------------------------------------------
# Dependencies - Install via package manager
# -----------------------------------------------------------------------------
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
yarn.lock
package-lock.json

# -----------------------------------------------------------------------------
# Python Virtual Environment - Create locally with: python3 -m venv .venv
# -----------------------------------------------------------------------------
.venv/
venv/
ENV/
env/
*.pyc
*.pyo
*.pyd
__pycache__/
*.so
.Python
*.egg
*.egg-info/
dist/
build/
.pytest_cache/
.coverage
htmlcov/

# Pre-trained ML Models (downloaded automatically - don't commit large binaries)
*.pt
*.pth
*.onnx
*.engine

# -----------------------------------------------------------------------------
# Next.js Build Artifacts - Generated by `npm run build`
# -----------------------------------------------------------------------------
.next/
/out/
build/

# -----------------------------------------------------------------------------
# Environment Variables - Copy .env.example and fill in your values
# -----------------------------------------------------------------------------
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local

# -----------------------------------------------------------------------------
# Logs and Debug Files
# -----------------------------------------------------------------------------
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
dev.log
server.log
prompt

# -----------------------------------------------------------------------------
# TypeScript Build Info
# -----------------------------------------------------------------------------
*.tsbuildinfo
next-env.d.ts

# -----------------------------------------------------------------------------
# IDE and Editor Files
# -----------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
.local-*
.claude
.z-ai-config

# -----------------------------------------------------------------------------
# Operating System Files
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# -----------------------------------------------------------------------------
# Testing and Coverage
# -----------------------------------------------------------------------------
coverage/
.nyc_output/

# -----------------------------------------------------------------------------
# Vercel Deployment
# -----------------------------------------------------------------------------
.vercel

# -----------------------------------------------------------------------------
# Temporary and Cache Files
# -----------------------------------------------------------------------------
tmp/
temp/
.cache/
.parcel-cache/

# -----------------------------------------------------------------------------
# Database Files (SQLite)
# -----------------------------------------------------------------------------
*.db
*.sqlite
*.sqlite3
!prisma/dev.db

# -----------------------------------------------------------------------------
# Documentation Internal Notes (optional - can be tracked if useful)
# -----------------------------------------------------------------------------
/docs/internal/

# -----------------------------------------------------------------------------
# Skills Directory (if used for testing)
# -----------------------------------------------------------------------------
/skills/

# -----------------------------------------------------------------------------
# Download Directory (generated files)
# -----------------------------------------------------------------------------
/download/